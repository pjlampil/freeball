<% content_for :title, "Sign up" %>

<div class="min-h-[80vh] flex flex-col items-center justify-center">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <div class="text-5xl mb-2">🎱</div>
      <h1 class="text-3xl font-black text-white">Freeball</h1>
      <p class="text-gray-400 mt-1">Create your account</p>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 space-y-4">
      <h2 class="text-lg font-bold text-white">Sign up</h2>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :name, class: "block text-sm text-gray-400 mb-1" %>
          <%= f.text_field :name, autofocus: true, autocomplete: "name",
              class: "w-full bg-gray-800 border border-gray-700 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-green-500" %>
        </div>

        <div>
          <%= f.label :email, class: "block text-sm text-gray-400 mb-1" %>
          <%= f.email_field :email, autocomplete: "email",
              class: "w-full bg-gray-800 border border-gray-700 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-green-500" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-sm text-gray-400 mb-1" %>
          <% if @minimum_password_length %>
            <p class="text-gray-500 text-xs mb-1"><%= @minimum_password_length %> characters minimum</p>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password",
              class: "w-full bg-gray-800 border border-gray-700 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-green-500" %>
        </div>

        <div>
          <%= f.label :password_confirmation, class: "block text-sm text-gray-400 mb-1" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "w-full bg-gray-800 border border-gray-700 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-green-500" %>
        </div>

        <%= f.submit "Create account", class: "w-full bg-green-600 hover:bg-green-500 text-white font-bold py-3 rounded-xl transition-colors cursor-pointer mt-2" %>
      <% end %>
    </div>

    <div class="mt-4 text-center">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
