<%- if controller_name != 'sessions' %>
  <p class="text-sm text-gray-400">
    Already have an account? <%= link_to "Sign in", new_session_path(resource_name), class: "text-green-400 hover:text-green-300 font-medium" %>
  </p>
<% end %>

<%- if devise_mapping.registerable? && controller_name != 'registrations' %>
  <p class="text-sm text-gray-400">
    New here? <%= link_to "Create an account", new_registration_path(resource_name), class: "text-green-400 hover:text-green-300 font-medium" %>
  </p>
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <p class="text-sm text-gray-400">
    <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-green-400 hover:text-green-300 font-medium" %>
  </p>
<% end %>
