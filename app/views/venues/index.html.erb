<% content_for :title, "Venues" %>

<div class="space-y-5">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold">Venues</h1>
    <%= link_to "New venue", new_venue_path, class: "bg-green-600 hover:bg-green-500 text-white font-medium px-4 py-2 rounded-xl transition-colors text-sm" %>
  </div>

  <% if @venues.empty? %>
    <p class="text-gray-500 text-sm">No venues yet.</p>
  <% else %>
    <div class="space-y-4">
      <% @venues.each do |venue| %>
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-5 space-y-3">
          <div class="flex items-center justify-between">
            <h2 class="font-bold text-white"><%= venue.name %></h2>
            <div class="flex items-center gap-3">
              <%= link_to "Edit", edit_venue_path(venue), class: "text-xs text-gray-500 hover:text-gray-300 transition-colors" %>
              <%= button_to "Delete", venue_path(venue), method: :delete,
                  form: { data: { turbo_confirm: "Delete #{venue.name} and all its tables?" } },
                  class: "text-xs text-red-700 hover:text-red-400 transition-colors bg-transparent border-0 cursor-pointer p-0" %>
            </div>
          </div>

          <% if venue.snooker_tables.any? %>
            <div class="space-y-1.5">
              <% venue.snooker_tables.order(:number, :name).each do |table| %>
                <div class="flex items-center justify-between bg-gray-800 rounded-xl px-3 py-2">
                  <span class="text-sm text-gray-300"><%= table.display_name %></span>
                  <%= button_to "Remove", venue_snooker_table_path(venue, table), method: :delete,
                      class: "text-xs text-red-800 hover:text-red-500 transition-colors bg-transparent border-0 cursor-pointer p-0" %>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-xs text-gray-600">No tables yet.</p>
          <% end %>

          <%= link_to "+ Add table", new_venue_snooker_table_path(venue),
              class: "text-xs text-green-600 hover:text-green-400 transition-colors" %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
