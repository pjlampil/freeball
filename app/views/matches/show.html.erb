<% content_for :title, "#{@match.player1.name} vs #{@match.player2.name}" %>

<div class="space-y-6">
  <div class="flex items-center gap-3">
    <% if user_signed_in? %>
      <%= link_to "←", matches_path, class: "text-gray-400 hover:text-white text-xl" %>
    <% end %>
    <span class="text-xs font-medium px-2 py-0.5 rounded-full <%= match_status_badge(@match) %>">
      <%= @match.status.humanize %>
    </span>
    <% if user_signed_in? && (@match.player1 == current_user || @match.player2 == current_user) %>
      <div class="ml-auto flex items-center gap-2">
        <%= link_to "Edit", edit_match_path(@match), class: "text-xs text-gray-500 hover:text-gray-300 transition-colors" %>
        <% unless @match.completed? %>
          <%= button_to "Delete", match_path(@match), method: :delete,
              form: { data: { turbo_confirm: "Delete this match and all its data? This cannot be undone." } },
              class: "text-xs text-red-700 hover:text-red-400 transition-colors bg-transparent border-0 cursor-pointer p-0" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Score header %>
  <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
    <div class="flex items-center justify-between">
      <div class="text-center flex-1">
        <p class="text-lg font-bold text-white"><%= @match.player1.name %></p>
        <p class="text-5xl font-black text-green-400 mt-2"><%= @match.player1_frames %></p>
      </div>
      <div class="text-center px-4 flex flex-col items-center gap-1.5">
        <p class="text-gray-500 text-sm mb-4">
          <% if @match.best_of %>
            Best of <%= @match.best_of %>
          <% else %>
            Open
          <% end %>
        </p>
        <% unless @match.standard? %>
          <p class="text-gray-600 text-xs">
            <%= @match.reds_count %> reds<%= " — stop at last red" if @match.stop_after_reds? %>
          </p>
        <% end %>
        <% if @match.in_progress? && @match.granular? && @match.current_frame %>
          <span class="text-xs font-semibold text-gray-400 bg-gray-800 border border-gray-700 px-2 py-0.5 rounded-full tabular-nums">
            <%= @match.current_frame.remaining_points %> remaining
          </span>
        <% end %>
      </div>
      <div class="text-center flex-1">
        <p class="text-lg font-bold text-white"><%= @match.player2.name %></p>
        <p class="text-5xl font-black text-green-400 mt-2"><%= @match.player2_frames %></p>
      </div>
    </div>

    <% if @match.completed? && @match.winner %>
      <div class="mt-4 text-center">
        <p class="text-green-400 font-semibold">🏆 <%= @match.winner.name %> wins!</p>
      </div>
    <% end %>
  </div>

  <%# Action buttons %>
  <% if @match.upcoming? && user_signed_in? %>
    <%= button_to "Start Match", start_match_path(@match), method: :post,
        class: "w-full bg-green-600 hover:bg-green-500 text-white font-bold py-4 rounded-2xl text-lg transition-colors" %>
  <% elsif @match.in_progress? && @match.current_frame %>
    <% if user_signed_in? %>
      <div class="flex gap-3">
        <%= link_to "Score this match →", frame_path(@match.current_frame),
            class: "flex-1 bg-green-600 hover:bg-green-500 text-white font-bold py-4 rounded-2xl text-lg transition-colors text-center" %>
        <%= link_to "📹 Live stream", stream_match_path(@match),
            class: "flex-1 bg-gray-800 hover:bg-gray-700 border border-gray-600 text-white font-bold py-4 rounded-2xl text-lg transition-colors text-center" %>
      </div>
    <% end %>
    <%= link_to "Watch live →", watch_match_path(@match),
        class: "block w-full bg-gray-800 hover:bg-gray-700 border border-gray-700 text-gray-300 font-bold py-4 rounded-2xl text-lg transition-colors text-center" %>
    <% if user_signed_in? && @match.best_of.nil? && @match.frames.completed.any? &&
          (@match.player1 == current_user || @match.player2 == current_user) %>
      <%= button_to "End match", finish_match_path(@match), method: :post,
          form: { data: { turbo_confirm: "End the match here? No more frames will be added." } },
          class: "w-full py-3 bg-transparent border border-gray-700 hover:border-red-900 text-gray-500 hover:text-red-400 text-sm font-medium rounded-2xl transition-colors" %>
    <% end %>
  <% end %>

  <%# Frames history %>
  <% if @match.frames.any? %>
    <div>
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">Frames</h2>
      <div class="space-y-2">
        <% @match.frames.order(:frame_number).each do |frame| %>
          <div class="bg-gray-900 border border-gray-800 rounded-xl px-4 py-3" style="position:relative; display:flex; align-items:center;">
            <span class="text-gray-500 text-sm" style="flex:1;">Frame <%= frame.frame_number %></span>
            <div style="position:absolute; left:50%; transform:translateX(-50%); display:flex; align-items:center; gap:0.5rem;">
              <span class="font-bold text-lg tabular-nums <%= frame.winner == @match.player1 ? 'text-green-400' : 'text-gray-300' %>"><%= frame.player1_score %></span>
              <span class="text-gray-600">–</span>
              <span class="font-bold text-lg tabular-nums <%= frame.winner == @match.player2 ? 'text-green-400' : 'text-gray-300' %>"><%= frame.player2_score %></span>
            </div>
            <div style="flex:1; display:flex; justify-content:flex-end; gap:0.75rem; align-items:center;">
              <% if frame.completed? %>
                <% if frame.duration %>
                  <span class="text-xs text-gray-600 tabular-nums"><%= format_duration(frame.duration) %></span>
                <% end %>
                <% if frame.winner %>
                  <span class="text-xs text-green-400 font-medium"><%= frame.winner.name %></span>
                <% end %>
                <% if @match.granular? %>
                  <%= link_to "Stats", stats_frame_path(frame), class: "text-xs text-gray-600 hover:text-gray-400" %>
                <% end %>
              <% elsif frame.in_progress? && user_signed_in? %>
                <%= link_to "Score", frame_path(frame), class: "text-xs text-green-400 hover:text-green-300 font-medium" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Match stats %>
  <% if @p1_stats %>
    <div>
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">Match stats</h2>
      <%= render "shared/stats_table", p1_stats: @p1_stats, p2_stats: @p2_stats %>
    </div>
  <% end %>
</div>
