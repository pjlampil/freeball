<% content_for :title, "My Matches" %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-white">Matches</h1>
    <%= link_to "New Match", new_match_path, class: "bg-green-600 hover:bg-green-500 text-white font-medium px-4 py-2 rounded-xl transition-colors" %>
  </div>

  <% if @matches.empty? %>
    <div class="text-center py-16">
      <div class="text-6xl mb-4">🎱</div>
      <p class="text-gray-400 text-lg">No matches yet.</p>
      <%= link_to "Create your first match", new_match_path, class: "mt-4 inline-block text-green-400 hover:text-green-300 font-medium" %>
    </div>
  <% else %>
    <div class="space-y-3">
      <% @matches.each do |match| %>
        <%= link_to match_path(match), class: "block bg-gray-900 hover:bg-gray-800 border border-gray-800 rounded-2xl p-4 transition-colors" do %>
          <div class="flex items-center justify-between mb-2">
            <span class="text-xs font-medium px-2 py-0.5 rounded-full <%= match_status_badge(match) %>">
              <%= match.status.humanize %>
            </span>
            <span class="text-gray-500 text-xs"><%= match.created_at.strftime("%b %d") %></span>
          </div>

          <div class="flex items-center justify-between">
            <div class="text-center flex-1">
              <p class="font-semibold text-white"><%= match.player1.name %></p>
            </div>
            <div class="text-center px-4">
              <div class="text-2xl font-bold">
                <span class="text-green-400"><%= match.player1_frames %></span>
                <span class="text-gray-600 mx-1">–</span>
                <span class="text-green-400"><%= match.player2_frames %></span>
              </div>
              <% if match.best_of %>
                <p class="text-gray-500 text-xs">Best of <%= match.best_of %></p>
              <% end %>
            </div>
            <div class="text-center flex-1">
              <p class="font-semibold text-white"><%= match.player2.name %></p>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
