<% content_for :title, "Match Stats" %>

<div class="space-y-5">
  <div class="flex items-center gap-3">
    <%= link_to "←", match_path(@match), class: "text-gray-400 hover:text-white text-xl" %>
    <div>
      <h1 class="text-lg font-bold">Match Stats</h1>
      <p class="text-xs text-gray-500"><%= @match.player1.name %> vs <%= @match.player2.name %></p>
    </div>
    <% if @match.in_progress? %>
      <span class="ml-auto text-xs font-medium text-green-400 bg-green-950/50 border border-green-900/50 px-2 py-1 rounded-full animate-pulse">
        Live
      </span>
    <% end %>
  </div>

  <div id="match-stats-content">
    <%= render "shared/stats_table", p1_stats: @p1_stats, p2_stats: @p2_stats %>
  </div>

  <% if @match.frames.completed.any? %>
    <div>
      <h2 class="text-xs font-semibold text-gray-600 uppercase tracking-wider mb-2">Frame breakdown</h2>
      <div class="space-y-2">
        <% @match.frames.completed.order(:frame_number).each do |frame| %>
          <div class="bg-gray-900 border border-gray-800 rounded-xl px-4 py-3 flex items-center justify-between gap-3">
            <span class="text-gray-500 text-sm shrink-0">Frame <%= frame.frame_number %></span>
            <div class="flex items-center gap-3 flex-1 justify-center">
              <span class="font-bold <%= frame.winner == @match.player1 ? 'text-green-400' : 'text-gray-400' %>"><%= frame.player1_score %></span>
              <span class="text-gray-700">–</span>
              <span class="font-bold <%= frame.winner == @match.player2 ? 'text-green-400' : 'text-gray-400' %>"><%= frame.player2_score %></span>
            </div>
            <div class="flex items-center gap-3 shrink-0">
              <% if frame.duration %>
                <span class="text-xs text-gray-600 tabular-nums"><%= format_duration(frame.duration) %></span>
              <% end %>
              <%= link_to "Stats", stats_frame_path(frame), class: "text-xs text-gray-600 hover:text-gray-400" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<% if @match.in_progress? %>
  <script type="module">
    const { default: consumer } = await import("channels/consumer")
    consumer.subscriptions.create(
      { channel: "MatchChannel", match_id: <%= @match.id %> },
      {
        received(data) {
          if (!data.stats_html) return
          const el = document.getElementById("match-stats-content")
          if (el) el.innerHTML = data.stats_html
        }
      }
    )
  </script>
<% end %>
