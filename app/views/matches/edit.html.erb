<% content_for :title, "Edit Match" %>

<div>
  <div class="flex items-center gap-3 mb-6">
    <%= link_to "←", match_path(@match), class: "text-gray-400 hover:text-white text-xl" %>
    <h1 class="text-2xl font-bold">Edit Match</h1>
  </div>

  <%= form_with model: @match, class: "space-y-5" do |f| %>
    <% if @match.errors.any? %>
      <div class="bg-red-900/50 border border-red-700 rounded-xl p-4">
        <ul class="text-red-300 text-sm space-y-1">
          <% @match.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-5 space-y-4">
      <h2 class="font-semibold text-gray-300 text-sm uppercase tracking-wider">Players</h2>

      <% if @match.frames.any? %>
        <div class="flex items-center justify-between text-sm">
          <span class="text-gray-400">Player 1</span>
          <span class="font-semibold text-white"><%= @match.player1.name %></span>
        </div>
        <div class="flex items-center justify-between text-sm">
          <span class="text-gray-400">Player 2</span>
          <span class="font-semibold text-white"><%= @match.player2.name %></span>
        </div>
        <p class="text-xs text-gray-600">Players cannot be changed once a match has started.</p>
      <% else %>
        <div>
          <%= f.label :player1_id, "Player 1", class: "block text-sm text-gray-400 mb-1" %>
          <%= f.select :player1_id, @users.map { |u| [ u.name, u.id ] },
              { include_blank: "Select player…" },
              class: "w-full bg-gray-800 border border-gray-700 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-green-500 appearance-none" %>
        </div>
        <div>
          <%= f.label :player2_id, "Player 2", class: "block text-sm text-gray-400 mb-1" %>
          <%= f.select :player2_id, @users.map { |u| [ u.name, u.id ] },
              { include_blank: "Select player…" },
              class: "w-full bg-gray-800 border border-gray-700 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-green-500 appearance-none" %>
        </div>
      <% end %>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-5 space-y-4">
      <h2 class="font-semibold text-gray-300 text-sm uppercase tracking-wider">Format</h2>

      <div>
        <%= f.label :best_of, "Best of (frames)", class: "block text-sm text-gray-400 mb-1" %>
        <% if @match.completed? %>
          <div class="flex items-center justify-between text-sm">
            <span class="font-semibold text-white"><%= @match.best_of ? "Best of #{@match.best_of}" : "Open-ended" %></span>
          </div>
          <p class="text-xs text-gray-600 mt-1">Cannot be changed on a completed match.</p>
        <% else %>
          <%= f.select :best_of,
              [ ["Open-ended", ""], [1,1], [3,3], [5,5], [7,7], [9,9], [11,11], [17,17], [19,19] ],
              { selected: @match.best_of },
              class: "w-full bg-gray-800 border border-gray-700 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-green-500 appearance-none" %>
        <% end %>
      </div>

      <% unless @match.frames.any? %>
        <div>
          <%= f.label :match_format, "Format", class: "block text-sm text-gray-400 mb-1" %>
          <div class="grid grid-cols-2 gap-3">
            <% [
                 [:standard,        "15 reds",        "Standard"],
                 [:ten_reds,        "10 reds",        "Shorter format"],
                 [:six_reds,        "6 reds",         "Quick format"],
                 [:stop_at_last_red,"15 reds — stop", "Ends when last red potted"],
               ].each do |value, title, subtitle| %>
              <label class="relative cursor-pointer">
                <%= f.radio_button :match_format, value, class: "sr-only peer" %>
                <div class="peer-checked:bg-green-600 peer-checked:border-green-500 bg-gray-800 border border-gray-700 rounded-xl p-3 text-center transition-colors">
                  <div class="font-medium text-sm"><%= title %></div>
                  <div class="text-gray-400 text-xs mt-0.5"><%= subtitle %></div>
                </div>
              </label>
            <% end %>
          </div>
        </div>

        <div>
          <%= f.label :scoring_mode, "Scoring mode", class: "block text-sm text-gray-400 mb-1" %>
          <div class="grid grid-cols-2 gap-3">
            <label class="relative cursor-pointer">
              <%= f.radio_button :scoring_mode, :granular, class: "sr-only peer" %>
              <div class="peer-checked:bg-green-600 peer-checked:border-green-500 bg-gray-800 border border-gray-700 rounded-xl p-3 text-center transition-colors">
                <div class="font-medium text-sm">Ball by ball</div>
                <div class="text-gray-400 text-xs mt-0.5">Full tracking</div>
              </div>
            </label>
            <label class="relative cursor-pointer">
              <%= f.radio_button :scoring_mode, :frame_score, class: "sr-only peer" %>
              <div class="peer-checked:bg-green-600 peer-checked:border-green-500 bg-gray-800 border border-gray-700 rounded-xl p-3 text-center transition-colors">
                <div class="font-medium text-sm">Frame score</div>
                <div class="text-gray-400 text-xs mt-0.5">Simple mode</div>
              </div>
            </label>
          </div>
        </div>

        <div>
          <%= f.label :visit_mode, "Visit tracking", class: "block text-sm text-gray-400 mb-1" %>
          <div class="grid grid-cols-2 gap-3">
            <label class="relative cursor-pointer">
              <%= f.radio_button :visit_mode, :breaks_only, class: "sr-only peer" %>
              <div class="peer-checked:bg-green-600 peer-checked:border-green-500 bg-gray-800 border border-gray-700 rounded-xl p-3 text-center transition-colors">
                <div class="font-medium text-sm">Breaks only</div>
                <div class="text-gray-400 text-xs mt-0.5">Visit logged when balls are potted</div>
              </div>
            </label>
            <label class="relative cursor-pointer">
              <%= f.radio_button :visit_mode, :all_turns, class: "sr-only peer" %>
              <div class="peer-checked:bg-green-600 peer-checked:border-green-500 bg-gray-800 border border-gray-700 rounded-xl p-3 text-center transition-colors">
                <div class="font-medium text-sm">All turns</div>
                <div class="text-gray-400 text-xs mt-0.5">Every approach logged</div>
              </div>
            </label>
          </div>
        </div>
      <% else %>
        <p class="text-xs text-gray-600">Match format and scoring mode cannot be changed once a match has started.</p>
      <% end %>
    </div>

    <%= f.submit "Save Changes", class: "w-full bg-green-600 hover:bg-green-500 text-white font-bold py-4 rounded-2xl text-lg transition-colors cursor-pointer" %>
  <% end %>
</div>
