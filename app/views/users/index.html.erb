<% content_for :title, "Users" %>

<div>
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">Users</h1>
    <%= link_to "New user", new_user_path,
        class: "bg-green-700 hover:bg-green-600 text-white font-semibold px-4 py-2 rounded-xl text-sm transition-colors" %>
  </div>

  <div class="bg-gray-900 border border-gray-800 rounded-2xl divide-y divide-gray-800">
    <% @users.each do |user| %>
      <div class="px-5 py-3 flex items-center justify-between gap-3">
        <div>
          <p class="font-medium text-white"><%= user.name %></p>
          <p class="text-gray-500 text-sm"><%= user.email %></p>
        </div>
        <% if user.superuser? %>
          <span class="text-xs font-semibold text-yellow-400 bg-yellow-950/60 border border-yellow-800/50 px-2 py-0.5 rounded-full">superuser</span>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
