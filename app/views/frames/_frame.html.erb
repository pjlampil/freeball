<%# POST-response target: replaced for the scorer on every action.
    id must be on this element itself so replace keeps working across updates. %>
<% match = frame.match %>
<% player1 = match.player1 %>
<% player2 = match.player2 %>
<% current_visit = frame.current_visit %>
<% current_player = frame.current_player %>
<% valid = frame.valid_balls %>
<% paused = frame.clock_paused? %>
<% undo_message = local_assigns[:undo_message] %>

<div id="frame-<%= frame.id %>" class="space-y-4">
  <script>
    (function() {
      var frameEl = document.getElementById("frame-<%= frame.id %>");
      if (!frameEl) return;

      // Disable all buttons on first submit to prevent double-tap duplicates
      frameEl.addEventListener("submit", function() {
        frameEl.querySelectorAll("button, input[type='submit']").forEach(function(b) { b.disabled = true; });
      }, { once: true });

      // Haptic feedback + reliable press animation on touchstart (no 300ms delay)
      frameEl.addEventListener("touchstart", function(e) {
        var btn = e.target.closest("button:not([disabled]), input[type='submit']:not([disabled])");
        if (!btn) return;
        if (navigator.vibrate) navigator.vibrate(10);
        // Reliable press scale — active: pseudo-class is flaky on iOS
        if (btn.classList.contains("scoring-btn")) {
          btn.style.transform = "scale(0.88)";
          var reset = function() { btn.style.transform = ""; btn.removeEventListener("touchend", reset); btn.removeEventListener("touchcancel", reset); };
          btn.addEventListener("touchend", reset);
          btn.addEventListener("touchcancel", reset);
        }
      }, { passive: true });
    })();
  </script>

  <% if undo_message %>
    <div class="bg-gray-800 border border-gray-700 text-gray-300 text-sm px-4 py-2.5 rounded-xl flex items-center gap-2">
      <span class="text-gray-500">↩</span> <%= undo_message %>
    </div>
  <% end %>

  <%# Scoreboard (also the broadcast target — see _scoreboard.html.erb) %>
  <%= render "frames/scoreboard", frame: frame %>

  <%# ── Controls ────────────────────────────────────────────── %>
  <% if frame.in_progress? && frame.pending_winner && user_signed_in? %>
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-5 space-y-4">
      <%= render "frames/clock_controls", frame: frame %>
      <% if paused %>
        <p class="text-center text-yellow-500 text-sm py-1">⏸ Clock paused — resume to continue scoring</p>
      <% else %>
      <div class="text-center space-y-1">
        <p class="text-xs text-gray-500 uppercase tracking-wider">Frame result</p>
        <p class="text-2xl font-black text-white"><%= frame.pending_winner.name %> wins</p>
        <% if frame.respotted_black? %>
          <p class="text-yellow-600 text-xs">Decided on the re-spotted black</p>
        <% end %>
      </div>
      <%= button_to "Confirm result →", confirm_result_frame_path(frame),
          method: :post,
          class: "w-full bg-green-700 hover:bg-green-600 text-white font-bold py-3 rounded-xl transition-colors active:scale-95" %>
      <%= button_to "↩ Undo last shot", undo_frame_path(frame),
          method: :post,
          class: "w-full py-2.5 bg-gray-800 hover:bg-gray-700 border border-gray-600 text-white text-sm font-medium rounded-xl transition-colors active:scale-95" %>
      <% end %>
    </div>

  <%# elsif frame.in_progress? && !user_signed_in? %>
    <!--<div class="bg-gray-900/50 border border-gray-800 rounded-2xl p-4 text-center">
      <p class="text-gray-400 text-sm">You're watching live.</p>
      <%= link_to "Sign in to score", new_user_session_path, class: "text-green-400 hover:text-green-300 text-sm font-medium" %>
    </div>-->

  <% elsif frame.in_progress? && match.granular? && user_signed_in? %>
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-4 space-y-5">

      <% unless paused || frame.started_at.nil? %>

      <% if frame.respotted_black? %>
        <div class="bg-gray-800 border border-yellow-800/60 rounded-xl px-3 py-2 text-center">
          <p class="text-yellow-400 font-semibold text-sm">Re-spotted black</p>
          <p class="text-gray-500 text-xs mt-0.5">Scores level — first to score wins</p>
        </div>
      <% end %>

      <% if current_visit&.active? %>
        <div class="flex items-center justify-between gap-3">
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wider">At the table</p>
            <p class="text-sm font-semibold text-green-400 mt-0.5"><%= current_player&.name %></p>
          </div>
          <%= button_to "End visit", end_visit_frame_path(frame),
              method: :post, params: { ended_by: :miss },
              class: "px-4 py-2 bg-gray-800 hover:bg-gray-700 border border-gray-600 text-gray-200 hover:text-white text-sm font-medium rounded-lg transition-colors active:scale-95 shrink-0" %>
        </div>

        <%# ── Ball buttons ───────────────────────────────────────── %>
        <div>
          <p class="text-xs text-gray-600 uppercase tracking-wider mb-3">Pot ball</p>
          <div class="grid grid-cols-4 gap-x-3 gap-y-4 justify-items-center">
            <%= render "frames/ball_button", visit: current_visit, ball: :red,    label: "Red",    value: 1, disabled: !valid.include?(:red) %>
            <%= render "frames/ball_button", visit: current_visit, ball: :yellow, label: "Yellow", value: 2, disabled: !valid.include?(:yellow) %>
            <%= render "frames/ball_button", visit: current_visit, ball: :green,  label: "Green",  value: 3, disabled: !valid.include?(:green) %>
            <%= render "frames/ball_button", visit: current_visit, ball: :brown,  label: "Brown",  value: 4, disabled: !valid.include?(:brown) %>
          </div>
          <div class="grid grid-cols-4 gap-x-3 gap-y-4 justify-items-center mt-4">
            <%= render "frames/ball_button", visit: current_visit, ball: :blue,  label: "Blue",  value: 5, disabled: !valid.include?(:blue) %>
            <%= render "frames/ball_button", visit: current_visit, ball: :pink,  label: "Pink",  value: 6, disabled: !valid.include?(:pink) %>
            <%= render "frames/ball_button", visit: current_visit, ball: :black, label: "Black", value: 7, disabled: !valid.include?(:black) %>
            <% free_avail = frame.free_ball_available? %>
            <%= button_to visit_shots_path(current_visit),
                method: :post,
                params: { shot: { ball: :free_ball, result: :potted } },
                disabled: !free_avail,
                class: "flex flex-col items-center gap-1 transition-all #{ free_avail ? 'active:scale-90' : 'opacity-20 cursor-not-allowed' }" do %>
              <div class="w-16 h-16 rounded-full ring-2 ring-white/10"
                   style="background: <%= ball_gradient(:free_ball) %>; <%= free_avail ? "box-shadow: #{ball_glow(:free_ball)};" : '' %>">
                <div class="w-full h-full rounded-full flex items-center justify-center">
                  <span class="font-black text-white/90 text-xs drop-shadow text-center leading-tight px-1">Free</span>
                </div>
              </div>
              <span class="text-xs font-medium <%= free_avail ? 'text-gray-400' : 'text-gray-700' %>">Free</span>
            <% end %>
          </div>
        </div>

        <%# ── Foul buttons ────────────────────────────────────────── %>
        <div>
          <p class="text-xs text-gray-600 uppercase tracking-wider mb-2">Foul</p>
          <div class="flex gap-2">
            <% [4, 5, 6, 7].each do |val| %>
              <%= button_to visit_shots_path(current_visit),
                  method: :post,
                  params: { shot: { ball: :red, result: :foul, foul_value: val } },
                  form_class: "flex-1",
                  class: "w-full flex items-center justify-center gap-1.5 py-3 bg-orange-950/70 hover:bg-orange-900/80 border border-orange-800/80 hover:border-orange-700 rounded-xl transition-colors active:scale-95" do %>
                <span class="text-orange-300 font-bold text-xl leading-none"><%= val %></span>
                <span class="text-orange-500 text-sm">pts</span>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <% end %>

      <%= render "frames/clock_controls", frame: frame %>

      <% if frame.started_at.nil? %>
        <%# clock controls above already show the Start button — nothing else needed %>
      <% elsif paused %>
        <p class="text-center text-yellow-500 text-sm">⏸ Clock paused — resume to continue scoring</p>
      <% else %>

      <%# ── Undo / End frame ───────────────────────────────────────── %>
      <% can_undo = frame.shots.any? || (current_visit&.visit_number.to_i > 1) %>
      <div class="space-y-2 pt-1 border-t border-gray-800">
        <p class="text-xs text-gray-600 uppercase tracking-wider text-left">End Frame</p>
        <div class="flex gap-2">
          <%= button_to "#{player1.name} wins", complete_frame_path(frame),
              method: :post, params: { winner_id: player1.id },
              form_class: "flex-1",
              class: "w-full bg-gray-800 hover:bg-green-950 border border-gray-600 hover:border-green-700 text-green-300 font-semibold py-4 rounded-xl transition-colors active:scale-95 text-base" %>
          <%= button_to "#{player2.name} wins", complete_frame_path(frame),
              method: :post, params: { winner_id: player2.id },
              form_class: "flex-1",
              class: "w-full bg-gray-800 hover:bg-green-950 border border-gray-600 hover:border-green-700 text-green-300 font-semibold py-4 rounded-xl transition-colors active:scale-95 text-base" %>
        </div>
        <div class="flex gap-2 mt-1">
          <%= button_to "− Remove red", remove_red_frame_path(frame),
              method: :post,
              disabled: frame.reds_remaining <= 0,
              form_class: "flex-1",
              class: "w-full py-2.5 bg-gray-800 hover:bg-gray-700 border border-gray-600 hover:border-red-700 text-white hover:text-red-400 text-sm font-medium rounded-xl transition-colors active:scale-95 #{ frame.reds_remaining <= 0 ? 'opacity-30 pointer-events-none' : '' }" %>
          <% if frame.removed_reds > 0 %>
            <%= button_to "↩ Restore red", restore_red_frame_path(frame),
                method: :post,
                form_class: "flex-1",
                class: "w-full py-2.5 bg-gray-800 hover:bg-gray-700 border border-gray-600 text-white text-sm font-medium rounded-xl transition-colors active:scale-95" %>
          <% end %>
        </div>
        <%= button_to "↩ Undo last action", undo_frame_path(frame),
            method: :post,
            disabled: !can_undo,
            form_class: "mt-1",
            class: "w-full py-2.5 bg-gray-800 hover:bg-gray-700 border border-gray-600 text-white text-sm font-medium rounded-xl transition-colors active:scale-95 #{ can_undo ? '' : 'opacity-30 pointer-events-none' }" %>
      </div>

      <% end %><%# end unless paused %>

    </div>

  <% elsif frame.in_progress? && match.frame_score? && user_signed_in? %>
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-5 space-y-3">
      <%= render "frames/clock_controls", frame: frame %>
      <% if paused %>
        <p class="text-center text-yellow-500 text-sm py-1">⏸ Clock paused — resume to continue scoring</p>
      <% else %>
        <p class="text-sm text-gray-400">Who won this frame?</p>
        <div class="grid grid-cols-2 gap-3">
          <%= button_to player1.name, complete_frame_path(frame),
              method: :post, params: { winner_id: player1.id },
              class: "bg-green-700 hover:bg-green-600 text-white font-bold py-4 rounded-xl transition-colors" %>
          <%= button_to player2.name, complete_frame_path(frame),
              method: :post, params: { winner_id: player2.id },
              class: "bg-green-700 hover:bg-green-600 text-white font-bold py-4 rounded-xl transition-colors" %>
        </div>
      <% end %>
    </div>

  <% elsif frame.completed? %>
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-5 text-center">
      <p class="text-green-400 font-bold text-lg">Frame complete</p>
      <% if frame.winner %>
        <p class="text-gray-300 mt-1"><%= frame.winner.name %> wins this frame</p>
        <% if frame.respotted_black? %>
          <p class="text-yellow-600 text-xs mt-1">Decided on the re-spotted black</p>
        <% end %>
      <% end %>
      <div class="mt-4 flex items-center justify-center gap-4">
        <%= link_to "Back to match →", match_path(match),
            class: "text-green-400 hover:text-green-300 font-medium" %>
        <% if match.granular? %>
          <%= link_to "Frame stats", stats_frame_path(frame),
              class: "text-gray-500 hover:text-gray-300 text-sm" %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Recent visits — shown separately below controls for granular frames %>
  <% if match.granular? %>
    <%= render "frames/recent_visits", frame: frame %>
  <% end %>

</div>
