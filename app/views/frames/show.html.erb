<% content_for :title, "Frame #{@frame.frame_number}" %>

<div class="flex items-center gap-3 mb-4">
  <%= link_to "←", match_path(@match), class: "text-gray-400 hover:text-white text-xl" %>
  <h1 class="text-lg font-bold">Frame <%= @frame.frame_number %></h1>
  <% if @match.best_of %>
    <span class="text-gray-500 text-sm">Best of <%= @match.best_of %></span>
  <% end %>
  <% if @frame.started_at %>
    <span id="frame-elapsed" class="ml-auto text-gray-500 text-sm font-mono tabular-nums"><%= "Frame #{format_duration(@frame.elapsed_seconds)}" %></span>
  <% end %>
</div>

<%= render "frames/frame", frame: @frame %>

<button type="button" id="wake-lock-toggle"
        class="w-full mt-2 py-2.5 bg-gray-800 hover:bg-gray-700 border border-gray-600 text-white text-sm font-medium rounded-xl transition-colors">
  ☀ Keep screen on: <span id="wake-lock-state">Off</span>
</button>

<% if @p1_stats %>
  <div id="frame-live-stats" class="mt-4">
    <p class="text-xs font-semibold text-gray-600 uppercase tracking-wider mb-2">Match stats</p>
    <%= render "shared/stats_table", p1_stats: @p1_stats, p2_stats: @p2_stats %>
  </div>
<% end %>


<script src="/assets/nosleep.min.js"></script>
<script>
  // ── Wake lock / keep screen on ───────────────────────────────────────────
  // Lives here (outside the replaced frame div) so state survives re-renders.
  (function() {
    var wakeLock = null;
    var noSleep = null;
    var noSleepActive = false;

    function isOn() { return !!(wakeLock || noSleepActive); }

    function updateWakeLockButton() {
      var btn = document.getElementById("wake-lock-toggle");
      var state = document.getElementById("wake-lock-state");
      if (!btn || !state) return;
      if (isOn()) {
        state.textContent = "On";
        btn.classList.remove("text-white", "border-gray-600");
        btn.classList.add("text-yellow-400", "border-yellow-800");
      } else {
        state.textContent = "Off";
        btn.classList.remove("text-yellow-400", "border-yellow-800");
        btn.classList.add("text-white", "border-gray-600");
      }
    }

    async function acquireWakeLock() {
      wakeLock = await navigator.wakeLock.request("screen");
      wakeLock.addEventListener("release", function() { wakeLock = null; updateWakeLockButton(); });
    }

    function enableNoSleep() {
      if (!noSleep) noSleep = new NoSleep();
      noSleep.enable();
      noSleepActive = true;
    }

    document.getElementById("wake-lock-toggle").addEventListener("click", async function() {
      if ("wakeLock" in navigator) {
        if (wakeLock) {
          await wakeLock.release(); wakeLock = null;
        } else {
          try { await acquireWakeLock(); }
          catch (e) { enableNoSleep(); }
        }
      } else if (typeof NoSleep !== "undefined") {
        if (noSleepActive) { noSleep.disable(); noSleepActive = false; }
        else { enableNoSleep(); }
      }
      sessionStorage.setItem("wakeLockEnabled", isOn() ? "true" : "false");
      updateWakeLockButton();
    });

    document.addEventListener("visibilitychange", async function() {
      if (wakeLock && document.visibilityState === "visible") {
        try { await acquireWakeLock(); updateWakeLockButton(); } catch (e) {}
      }
    });

    // Restore saved preference on page load
    if (sessionStorage.getItem("wakeLockEnabled") === "true") {
      if ("wakeLock" in navigator) {
        acquireWakeLock().then(updateWakeLockButton).catch(function() {});
      } else if (typeof NoSleep !== "undefined") {
        enableNoSleep();
        updateWakeLockButton();
      }
    }
  })();
</script>

<script type="module">
  // Submit any form inside the scoring frame without a full page load.
  // Follows the redirect, parses the response, and swaps the frame div in-place.
  const frameId = "frame-<%= @frame.id %>"
  let suppressWsUpdate = false

  document.addEventListener("submit", async function(e) {
    const frame = document.getElementById(frameId)
    if (!frame || !frame.contains(e.target)) return
    e.preventDefault()
    suppressWsUpdate = true
    const form = e.target
    const resp = await fetch(form.action, { method: form.method, body: new FormData(form), redirect: "follow", headers: { "Accept": "text/html" } })
    if (resp.redirected) { window.location = resp.url; return }
    const html = await resp.text()
    const doc = new DOMParser().parseFromString(html, "text/html")
    const fresh = doc.getElementById(frameId)
    if (fresh) document.getElementById(frameId)?.replaceWith(fresh)
    setTimeout(() => { suppressWsUpdate = false }, 2000)
  }, true)

  // Live scoreboard updates for spectators
  const { default: consumer } = await import("channels/consumer")
  setWsStatus("connecting")
  consumer.subscriptions.create(
    { channel: "MatchChannel", match_id: <%= @match.id %> },
    {
      connected()    { setWsStatus("connected") },
      disconnected() { setWsStatus("error") },
      received(data) {
        if (suppressWsUpdate) return
        const frameEl = document.getElementById(`frame-${data.frame_id}`)
        if (!frameEl) return
        // Re-fetch to get correct button states for this user
        fetch(window.location.href, { headers: { "Accept": "text/html" }, redirect: "follow" })
          .then(r => r.text())
          .then(html => {
            const doc = new DOMParser().parseFromString(html, "text/html")
            const fresh = doc.getElementById(`frame-${data.frame_id}`)
            if (fresh) frameEl.outerHTML = fresh.outerHTML
            const freshStats = doc.getElementById("frame-live-stats")
            const statsEl = document.getElementById("frame-live-stats")
            if (freshStats && statsEl) statsEl.outerHTML = freshStats.outerHTML
          })
      }
    }
  )
</script>
