<%# Locals: visit, ball (symbol), label (string), value (int), disabled (bool) %>
<% is_disabled = local_assigns[:disabled] || false %>

<%= button_to visit_shots_path(visit),
    method: :post,
    params: { shot: { ball: ball, result: :potted } },
    disabled: is_disabled,
    class: "flex flex-col items-center gap-1 transition-all #{ is_disabled ? 'opacity-20 cursor-not-allowed' : 'scoring-btn' }" do %>
  <div class="w-16 h-16 rounded-full ring-2 ring-white/10 transition-transform"
       style="background: <%= ball_gradient(ball) %>; <%= is_disabled ? '' : "box-shadow: #{ball_glow(ball)};" %>">
    <div class="w-full h-full rounded-full flex items-center justify-center">
      <span class="font-black text-white/90 text-base drop-shadow"><%= value %></span>
    </div>
  </div>
  <span class="text-xs font-medium <%= is_disabled ? 'text-gray-700' : 'text-gray-400' %>"><%= label %></span>
<% end %>
