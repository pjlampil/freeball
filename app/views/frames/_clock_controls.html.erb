<div data-frame-started-at="<%= frame.started_at&.to_i %>"
     data-frame-paused-at="<%= frame.paused_at&.to_i %>"
     data-frame-total-paused="<%= frame.total_paused_seconds %>">

  <div class="flex items-center justify-between gap-3">
    <% if frame.started_at.nil? %>
      <%= button_to "▶ Start frame", start_clock_frame_path(frame), method: :post,
          class: "w-full p-3 bg-green-950/50 border border-green-900/60 hover:bg-green-900/50 text-green-400 text-sm font-semibold rounded-xl transition-colors active:scale-95" %>

    <% elsif frame.clock_paused? %>
      <div class="flex items-center gap-2">
        <span class="text-yellow-500 text-xs">⏸</span>
        <span class="text-gray-400 text-sm font-mono tabular-nums"><%= format_duration(frame.elapsed_seconds) %></span>
        <span class="text-xs text-yellow-700 font-medium">Paused</span>
      </div>
      <%= button_to "▶ Resume", pause_clock_frame_path(frame), method: :post,
          class: "px-4 py-1.5 bg-yellow-950/50 border border-yellow-900/60 hover:bg-yellow-900/50 text-yellow-400 text-xs font-semibold rounded-xl transition-colors active:scale-95 shrink-0" %>

    <% else %>
      <div class="flex items-center gap-2">
        <span class="text-green-500 text-xs">⏱</span>
        <span class="text-gray-300 text-sm font-mono tabular-nums" id="frame-clock-display"><%= format_duration(frame.elapsed_seconds) %></span>
      </div>
      <%= button_to "⏸ Pause", pause_clock_frame_path(frame), method: :post,
          class: "px-4 py-1.5 bg-gray-800 hover:bg-gray-700 border border-gray-700 text-gray-400 hover:text-gray-300 text-xs font-medium rounded-xl transition-colors active:scale-95 shrink-0" %>
    <% end %>
  </div>

</div>
