<% content_for :title, "Frame #{@frame.frame_number} Stats" %>

<div class="space-y-5">
  <div class="flex items-center gap-3">
    <%= link_to "←", frame_path(@frame), class: "text-gray-400 hover:text-white text-xl" %>
    <div>
      <h1 class="text-lg font-bold">Frame <%= @frame.frame_number %> Stats</h1>
      <p class="text-xs text-gray-500"><%= @match.player1.name %> vs <%= @match.player2.name %></p>
    </div>
    <% if @frame.winner %>
      <span class="ml-auto text-xs font-medium text-green-400 bg-green-950/50 border border-green-900/50 px-2 py-1 rounded-full">
        <%= @frame.winner.name %> won <%= @frame.player1_score %>–<%= @frame.player2_score %>
      </span>
    <% end %>
  </div>

  <% if @frame.started_at && @frame.completed_at %>
    <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden">
      <div class="border-b border-gray-800 px-4 py-2.5">
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Timing</h2>
      </div>
      <div class="divide-y divide-gray-800/60">
        <div class="flex justify-between items-center px-4 py-2.5">
          <span class="text-xs text-gray-500">Frame duration</span>
          <span class="text-sm font-semibold text-gray-300 tabular-nums"><%= format_duration(@frame.duration) %></span>
        </div>
        <% if @frame.reds_cleared_at %>
          <div class="flex justify-between items-center px-4 py-2.5">
            <span class="text-xs text-gray-500">Reds phase</span>
            <span class="text-sm font-semibold text-gray-300 tabular-nums"><%= format_duration(@frame.reds_phase_duration) %></span>
          </div>
          <div class="flex justify-between items-center px-4 py-2.5">
            <span class="text-xs text-gray-500">Colours phase</span>
            <span class="text-sm font-semibold text-gray-300 tabular-nums"><%= format_duration(@frame.colors_phase_duration) %></span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%= render "shared/stats_table", p1_stats: @p1_stats, p2_stats: @p2_stats %>

  <%# Tab selector %>
  <div class="flex gap-1 bg-gray-900 border border-gray-800 rounded-xl p-1">
    <button type="button" id="tab-visits"
            onclick="showTab('visits')"
            class="flex-1 text-center text-sm font-medium py-1.5 rounded-lg transition-colors bg-gray-700 text-white">
      Visits
    </button>
    <button type="button" id="tab-points"
            onclick="showTab('points')"
            class="flex-1 text-center text-sm font-medium py-1.5 rounded-lg transition-colors text-gray-500 hover:text-gray-300">
      Points
    </button>
  </div>

  <div id="panel-visits">

    <% all_visits = @frame.visits.includes(:shots, :player).order(:visit_number) %>
    <% if all_visits.any? %>
      <div class="space-y-1.5">
        <% all_visits.each do |visit| %>
          <div class="bg-gray-900 border border-gray-800 rounded-xl px-3 py-2.5 flex items-center justify-between gap-2">
            <div class="flex items-center gap-2 min-w-0">
              <span class="text-sm text-gray-300 font-medium truncate"><%= visit.player.name %></span>
              <% if visit.ended_by %>
                <span class="text-xs text-gray-700 capitalize shrink-0">(<%= visit.ended_by.humanize %>)</span>
              <% end %>
            </div>
            <div class="flex items-center gap-1 shrink-0">
              <% visit.shots.each do |shot| %>
                <span class="<%= ball_dot_color(shot.ball) %> w-5 h-5 rounded-full text-xs flex items-center justify-center font-bold shrink-0"
                      title="<%= shot.ball.humanize %>: <%= shot.foul? ? "Foul +#{shot.foul_value}" : "+#{shot.points}" %>">
                  <%= shot.foul? ? "F" : shot.points %>
                </span>
              <% end %>
              <span class="text-yellow-400 font-bold text-sm ml-1"><%= visit.break_score %></span>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div><%# end panel-visits %>

  <div id="panel-points" style="display:none">
    <% if @points_series.empty? %>
      <div class="text-center py-16 text-gray-500">No shot data recorded for this frame.</div>
    <% else %>
      <div class="bg-gray-900 border border-gray-800 rounded-2xl p-4">
        <div class="flex items-center justify-between mb-3">
          <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Points over time</span>
          <span class="text-xs text-gray-600"><%= @points_series.length %> shots</span>
        </div>
        <canvas id="points-chart" style="max-height: 300px"></canvas>
      </div>
    <% end %>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
  <script>
    function showTab(name) {
      ["visits", "points"].forEach(function(t) {
        document.getElementById("panel-" + t).style.display = t === name ? "" : "none";
        var btn = document.getElementById("tab-" + t);
        if (t === name) {
          btn.classList.add("bg-gray-700", "text-white");
          btn.classList.remove("text-gray-500", "hover:text-gray-300");
        } else {
          btn.classList.remove("bg-gray-700", "text-white");
          btn.classList.add("text-gray-500", "hover:text-gray-300");
        }
      });
      if (name === "points" && !window._pointsChartInit) {
        window._pointsChartInit = true;
        const series = <%= raw @points_series.to_json %>;
        new Chart(document.getElementById("points-chart"), {
          type: "line",
          data: {
            labels: series.map((_, i) => i + 1),
            datasets: [
              {
                label: <%= raw @match.player1.name.to_json %>,
                data: series.map(d => d.p1),
                borderColor: "#22c55e",
                backgroundColor: "rgba(34,197,94,0.08)",
                pointRadius: 0,
                borderWidth: 2,
                tension: 0.1,
                fill: false
              },
              {
                label: <%= raw @match.player2.name.to_json %>,
                data: series.map(d => d.p2),
                borderColor: "rgba(255,255,255,0.4)",
                backgroundColor: "transparent",
                pointRadius: 0,
                borderWidth: 2,
                tension: 0.1,
                fill: false
              }
            ]
          },
          options: {
            responsive: true,
            interaction: { mode: "index", intersect: false },
            plugins: {
              legend: { labels: { color: "#9ca3af", font: { size: 11 } } },
              tooltip: {
                backgroundColor: "#1f2937",
                titleColor: "#e5e7eb",
                bodyColor: "#9ca3af",
                borderColor: "#374151",
                borderWidth: 1,
                callbacks: { title: ctx => `Shot ${ctx[0].label}` }
              }
            },
            scales: {
              x: {
                title: { display: true, text: "Shot", color: "#4b5563", font: { size: 10 } },
                ticks: { color: "#4b5563", maxTicksLimit: 10, font: { size: 10 } },
                grid: { color: "rgba(255,255,255,0.04)" }
              },
              y: {
                beginAtZero: true,
                ticks: { color: "#4b5563", font: { size: 10 } },
                grid: { color: "rgba(255,255,255,0.04)" }
              }
            }
          }
        });
      }
    }
  </script>

  <%= link_to "Match stats →", stats_match_path(@match),
      class: "block text-center text-sm text-gray-500 hover:text-gray-300 transition-colors py-2" %>
</div>
