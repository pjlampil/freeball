<% content_for :title, "Frame #{@frame.frame_number} Stats" %>

<div class="space-y-5">
  <div class="flex items-center gap-3">
    <%= link_to "←", frame_path(@frame), class: "text-gray-400 hover:text-white text-xl" %>
    <div>
      <h1 class="text-lg font-bold">Frame <%= @frame.frame_number %> Stats</h1>
      <p class="text-xs text-gray-500"><%= @match.player1.name %> vs <%= @match.player2.name %></p>
    </div>
    <% if @frame.winner %>
      <span class="ml-auto text-xs font-medium text-green-400 bg-green-950/50 border border-green-900/50 px-2 py-1 rounded-full">
        <%= @frame.winner.name %> won <%= @frame.player1_score %>–<%= @frame.player2_score %>
      </span>
    <% end %>
  </div>

  <% if @frame.started_at && @frame.completed_at %>
    <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden">
      <div class="border-b border-gray-800 px-4 py-2.5">
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Timing</h2>
      </div>
      <div class="divide-y divide-gray-800/60">
        <div class="flex justify-between items-center px-4 py-2.5">
          <span class="text-xs text-gray-500">Frame duration</span>
          <span class="text-sm font-semibold text-gray-300 tabular-nums"><%= format_duration(@frame.duration) %></span>
        </div>
        <% if @frame.reds_cleared_at %>
          <div class="flex justify-between items-center px-4 py-2.5">
            <span class="text-xs text-gray-500">Reds phase</span>
            <span class="text-sm font-semibold text-gray-300 tabular-nums"><%= format_duration(@frame.reds_phase_duration) %></span>
          </div>
          <div class="flex justify-between items-center px-4 py-2.5">
            <span class="text-xs text-gray-500">Colours phase</span>
            <span class="text-sm font-semibold text-gray-300 tabular-nums"><%= format_duration(@frame.colors_phase_duration) %></span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%= render "shared/stats_table", p1_stats: @p1_stats, p2_stats: @p2_stats %>

  <%= link_to "Match stats →", stats_match_path(@match),
      class: "block text-center text-sm text-gray-500 hover:text-gray-300 transition-colors py-2" %>
</div>
