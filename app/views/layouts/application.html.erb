<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Freeball" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Freeball">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="server-time" content="<%= Time.current.to_i %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script>
      function fmtDuration(seconds) {
        var h = Math.floor(seconds / 3600)
        var m = Math.floor((seconds % 3600) / 60)
        return h + ":" + String(m).padStart(2, "0")
      }

      // Correct for client/server clock skew once on page load
      var _serverOffset = (function() {
        var meta = document.querySelector('meta[name="server-time"]')
        return meta ? parseInt(meta.content) - Math.floor(Date.now() / 1000) : 0
      })()

      function updateTimers() {
        var now = Math.floor(Date.now() / 1000) + _serverOffset

        // Frame elapsed header + frame-clock-display in controls partial
        // Both read state from the clock-controls div (inside the replaced partial, always fresh)
        var clockDiv = document.querySelector("[data-frame-started-at]")
        if (clockDiv) {
          var startedAt   = parseInt(clockDiv.dataset.frameStartedAt  || "0")
          var totalPaused = parseInt(clockDiv.dataset.frameTotalPaused || "0")
          var pausedAt    = parseInt(clockDiv.dataset.framePausedAt    || "0")
          if (startedAt) {
            var endpoint = pausedAt ? pausedAt : now
            var elapsed  = Math.max(0, endpoint - startedAt - totalPaused)
            var frameElapsed = document.getElementById("frame-elapsed")
            if (frameElapsed) frameElapsed.textContent = "Frame " + fmtDuration(elapsed)
            var clockDisplay = document.getElementById("frame-clock-display")
            if (clockDisplay && !pausedAt) clockDisplay.textContent = fmtDuration(elapsed)
          }
        }

        // Match elapsed in watch view (element lives inside watch-content, replaced on updates)
        var matchEl = document.getElementById("match-elapsed")
        if (matchEl) {
          var matchStart = parseInt(matchEl.dataset.startedAt || "0")
          var framePausedAt = parseInt(matchEl.dataset.framePausedAt || "0")
          if (matchStart) {
            var matchEndpoint = framePausedAt ? framePausedAt : now
            matchEl.textContent = "Match " + fmtDuration(Math.max(0, matchEndpoint - matchStart))
          }
        }
      }

      setInterval(updateTimers, 1000)
    </script>
    <script>
      document.addEventListener("touchmove", function(e) {
        if (e.touches.length > 1) e.preventDefault()
      }, { passive: false })
      var lastTouchEnd = 0
      document.addEventListener("touchend", function(e) {
        var now = Date.now()
        if (now - lastTouchEnd < 300) e.preventDefault()
        lastTouchEnd = now
      }, { passive: false })
    </script>
  </head>

  <body class="bg-gray-950 text-white min-h-screen overflow-x-hidden">
    <nav class="bg-gray-900 border-b border-gray-800 px-4 py-3 flex items-center justify-between sticky top-0 z-50">
      <a href="<%= root_path %>" class="text-green-400 font-bold text-xl tracking-tight">
        🎱 Freeball
      </a>
      <% if user_signed_in? %>
        <div class="flex items-center gap-3">
          <span class="text-gray-400 text-sm hidden sm:block"><%= current_user.name %></span>
          <% if current_user.superuser? %>
            <%= link_to "Users", users_path, class: "text-gray-400 hover:text-white text-sm transition-colors hidden sm:block" %>
          <% end %>
          <%= link_to "New Match", new_match_path, class: "bg-green-600 hover:bg-green-500 text-white text-sm font-medium px-3 py-1.5 rounded-lg transition-colors" %>
          <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "text-gray-400 hover:text-white text-sm transition-colors" %>
        </div>
      <% end %>
    </nav>

    <% if notice.present? %>
      <div class="bg-green-900/50 border border-green-700 text-green-300 px-4 py-3 mx-4 mt-4 rounded-lg text-sm" role="alert">
        <%= notice %>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="bg-red-900/50 border border-red-700 text-red-300 px-4 py-3 mx-4 mt-4 rounded-lg text-sm" role="alert">
        <%= alert %>
      </div>
    <% end %>

    <main class="px-4 py-6 max-w-2xl mx-auto">
      <%= yield %>
    </main>
  </body>
</html>
